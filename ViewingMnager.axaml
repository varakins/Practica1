<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="Practica1.ViewingMnager"
        Title="ViewingMnager"
        Width="800"
        Height="600"
        MinWidth="800"
        MinHeight="600"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen">
  
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" 
                   Width="40" 
                   Height="40" 
                   Source="/Assets/Icon.ico"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1" 
                       Text="Просмотр товаров" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Margin="-30,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Spacing="20" 
                    Margin="0,0,0,20">
            
            <StackPanel Orientation="Vertical" Spacing="5">
                <TextBlock Text="Поиск:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="SearchTextBox"
                         Width="200"
                         Height="35"
                         Padding="10,5"
                         CornerRadius="5"
                         Background="#7FFF00"
                         Watermark="Введите текст для поиска..."
                         TextChanged="OnSearchTextChanged"/>
            </StackPanel>
            
            <StackPanel Orientation="Vertical" Spacing="5">
                <TextBlock Text="Сортировка по количеству:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="SortComboBox"
                          Width="200"
                          Height="35"
                          CornerRadius="5"
                          Background="White"
                          PlaceholderText="Выберите..."
                          SelectionChanged="OnSortSelectionChanged">
                    <ComboBoxItem Content="Без сортировки"/>
                    <ComboBoxItem Content="По возрастанию"/>
                    <ComboBoxItem Content="По убыванию"/>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Orientation="Vertical" Spacing="5">
                <TextBlock Text="Фильтр по поставщику:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="FilterComboBox"
                          Width="200"
                          Height="35"
                          CornerRadius="5"
                          Background="White"
                          PlaceholderText="Выберите поставщика..."
                          SelectionChanged="OnFilterSelectionChanged">
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <ListBox Grid.Row="2"
                 x:Name="ProductsListBox"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Margin="0,0,0,20">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="10"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <Button Grid.Row="3" 
                x:Name="BackButton"
                Content="Назад"
                Width="100"
                Height="40"
                HorizontalAlignment="Left"
                Background="#00FA9A"
                BorderThickness="0"
                CornerRadius="5"
                Click="OnBackButtonClick"/>
    </Grid>
</Window>