<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="450"
        x:Class="Practica1.ManagerMenu"
        Title="Меню менеджера"
        Height="450"
        Width="450"
        MaxHeight="450"
        MinWidth="450"
        MinHeight="450"
        MaxWidth="450"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" 
                   Width="40" 
                   Height="40" 
                   Source="/Assets/Icon.ico"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1" 
                       Text="Меню менеджера" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Margin="-30,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Spacing="20">
            
            <Button x:Name="ViewProductsButton"
                    Background="#00FA9A" 
                    Width="250"
                    Height="50"
                    CornerRadius="5"
                    HorizontalAlignment="Center"
                    Click="OnViewProductsClick">
                <TextBlock Text="Просмотр товаров" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            
            <Button Background="#00FA9A" 
                    Width="250"
                    Height="50"
                    CornerRadius="5"
                    HorizontalAlignment="Center"
                    Click="OnOrderManagerClick">
                <TextBlock Text="Просмотр заказов" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
        </StackPanel>

        <Button Grid.Row="2" 
                x:Name="BackButton"
                Content="Назад"
                Width="100"
                Height="40"
                HorizontalAlignment="Left"
                Background="#00FA9A"
                BorderThickness="0"
                CornerRadius="5"
                Click="OnBackButtonClick"/>
    </Grid>
</Window>